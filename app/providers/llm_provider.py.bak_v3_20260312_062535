class LLMQuestionProvider:
    def __init__(self) -> None:
        self.client = AsyncOpenAI(api_key=settings.openai_api_key, base_url=settings.openai_base_url)
        self.model = settings.openai_model

    async def generate_question(self, used_keys: set[str], preferred_category: str = CATEGORY_RANDOM) -> QuizQuestion:
        try:
            payload = await self._generate_via_llm(used_keys=used_keys, preferred_category=preferred_category)
            key = self._question_key(payload.question, payload.answer)
            return QuizQuestion(**payload.model_dump(), key=key, source='llm')
        except Exception as exc:
            logger.exception('LLM question generation failed: %s', exc)
            fallback = self._pick_fallback_question(used_keys=used_keys, preferred_category=preferred_category)
            fallback['key'] = self._question_key(fallback['question'], fallback['answer'])
            return QuizQuestion(**fallback, source='fallback')

    async def _generate_via_llm(self, used_keys: set[str], preferred_category: str) -> QuestionPayload:
        used_block = '\n'.join(f'- {item}' for item in list(used_keys)[-20:]) or '- повторов пока нет'

        if preferred_category == CATEGORY_RANDOM:
            category_instruction = (
                'Выбери одну массово понятную категорию из списка: '
                + ', '.join(SUPPORTED_CATEGORIES)
                + '.'
            )
        else:
            category_instruction = f'Категория должна быть строго: {preferred_category}.'

        user_prompt = f"""
Сгенерируй один вопрос для группового чата Telegram.

Условия:
- не повторять эти вопросы или их смысл:
{used_block}
- {category_instruction}
- вопрос должен быть понятным большинству людей
- уровень сложности: medium
- верни только JSON
""".strip()

        response = await self.client.chat.completions.create(
            model=self.model,
            temperature=0.6,
            messages=[
                {'role': 'system', 'content': SYSTEM_PROMPT},
                {'role': 'user', 'content': user_prompt},
            ],
        )

        content = response.choices[0].message.content or ''
        payload = self._parse_payload(content)

        if preferred_category != CATEGORY_RANDOM:
            payload.category = preferred_category
        else:
            payload.category = self._normalize_category(payload.category)

        return payload

    def _parse_payload(self, content: str) -> QuestionPayload:
        raw = self._extract_json_object(content)
        data: Any = json.loads(raw)

        aliases = data.get('aliases', [])
        if not isinstance(aliases, list):
            aliases = [str(aliases)]

        normalized = {
            'category': str(data.get('category', 'Общие знания')).strip() or 'Общие знания',
            'difficulty': str(data.get('difficulty', 'medium')).strip().lower() or 'medium',
            'question': str(data.get('question', '')).strip(),
            'answer': str(data.get('answer', '')).strip(),
            'aliases': [str(item).strip() for item in aliases if str(item).strip()],
            'hint': str(data.get('hint', '')).strip(),
            'explanation': str(data.get('explanation', '')).strip(),
        }
        return QuestionPayload.model_validate(normalized)

    def _extract_json_object(self, content: str) -> str:
        raw = content.strip()

        if raw.startswith('```'):
            raw = raw.strip('`').strip()
            if raw.lower().startswith('json'):
                raw = raw[4:].strip()

        first = raw.find('{')
        last = raw.rfind('}')
        if first == -1 or last == -1 or last <= first:
            logger.warning('LLM raw response without JSON: %s', content[:500])
            raise ValueError('LLM did not return a JSON object.')

        return raw[first:last + 1]

    def _normalize_category(self, category: str) -> str:
        category_norm = normalize_text(category)
        for item in SUPPORTED_CATEGORIES:
            if normalize_text(item) == category_norm:
                return item
        return 'Общие знания'

    def _question_key(self, question: str, answer: str) -> str:
        return f'{normalize_text(question)}|{normalize_text(answer)}'

    def _pick_fallback_question(self, used_keys: Iterable[str], preferred_category: str) -> dict[str, Any]:
        used_set = set(used_keys)

        if preferred_category != CATEGORY_RANDOM:
            pool = [item for item in FALLBACK_QUESTIONS if item['category'] == preferred_category]
            if not pool:
                pool = FALLBACK_QUESTIONS[:]
        else:
            pool = FALLBACK_QUESTIONS[:]

        candidates = [item for item in pool if self._question_key(item['question'], item['answer']) not in used_set]
        if not candidates:
            candidates = pool[:]
        if not candidates:
            candidates = FALLBACK_QUESTIONS[:]

        return random.choice(candidates).copy()
