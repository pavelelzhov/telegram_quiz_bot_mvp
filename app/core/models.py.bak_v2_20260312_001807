from __future__ import annotations

from dataclasses import dataclass, field
from typing import Dict, List, Optional, Set


@dataclass(slots=True)
class QuizQuestion:
    category: str
    difficulty: str
    question: str
    answer: str
    aliases: List[str]
    hint: str
    explanation: str
    source: str = 'llm'


@dataclass(slots=True)
class PlayerScore:
    user_id: int
    username: str
    points: int = 0


@dataclass(slots=True)
class GameState:
    chat_id: int
    started_by_user_id: int
    question_limit: int
    asked_count: int = 0
    current_question: Optional[QuizQuestion] = None
    current_question_answered: bool = False
    scores: Dict[int, PlayerScore] = field(default_factory=dict)
    used_questions: Set[str] = field(default_factory=set)
    hints_used_for_current_question: int = 0
    is_active: bool = True
