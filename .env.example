BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

YANDEX_SEARCH_API_KEY=
YANDEX_SEARCH_FOLDER_ID=

QUESTION_TIMEOUT_SEC=30
MAX_HINTS_PER_QUESTION=1
DEFAULT_QUESTION_COUNT=25
RECENT_QUESTIONS_LIMIT=100
LOG_LEVEL=INFO

ALISA_ENABLED=true
ALISA_NAME=Алиса
ALISA_NAME_ALIASES=алиса
ALISA_ONLY_REPLY_ON_NAME=true
ALISA_ALLOW_REPLY_TO_MESSAGE=true
ALISA_ALLOW_MENTION=true
ALISA_DISABLE_GENERIC_BOT_TRIGGERS=true

ALISA_INITIATIVE_ENABLED=true
ALISA_MAX_INITIATIVES_PER_DAY=3
ALISA_MIN_MINUTES_BETWEEN_INITIATIVES=90
ALISA_MIN_MESSAGES_WINDOW_FOR_INITIATIVE=12
ALISA_MIN_UNIQUE_USERS_FOR_INITIATIVE=3
ALISA_MAX_RECENT_TENSION_FOR_INITIATIVE=0.45

ALISA_REPLY_MAX_SENTENCES=3
ALISA_REPLY_MAX_CHARS=220
ALISA_SUPPORT_MAX_CHARS=260

ALISA_DEFAULT_SHARPNESS=medium
ALISA_DEFAULT_HUMOR=medium
ALISA_ROAST_POLICY=guarded
ALISA_AI_PHRASE_FILTER=true
ALISA_SELF_CHECK_ENABLED=true

ALISA_COOLDOWN_ADDRESSED_SECONDS=8
ALISA_COOLDOWN_INITIATIVE_SECONDS=2100
ALISA_COOLDOWN_PUSHBACK_SECONDS=12

ALISA_MEMORY_SUMMARY_MAX_CHARS=300
ALISA_HISTORY_WINDOW_SIZE=30
