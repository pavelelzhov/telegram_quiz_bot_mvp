class LLMQuestionProvider:
    def __init__(self) -> None:
        self.client = AsyncOpenAI(api_key=settings.openai_api_key, base_url=settings.openai_base_url)
        self.model = settings.openai_model

    async def generate_question(self, used_questions: set[str]) -> QuizQuestion:
        try:
            payload = await self._generate_via_llm(used_questions)
            return QuizQuestion(**payload.model_dump(), source='llm')
        except Exception as exc:
            logger.exception('LLM question generation failed: %s', exc)
            fallback = self._pick_fallback_question(used_questions)
            return QuizQuestion(**fallback, source='fallback')

    async def _generate_via_llm(self, used_questions: set[str]) -> QuestionPayload:
        used_block = '\n'.join(f'- {item}' for item in list(used_questions)[-12:]) or '- повторов пока нет'

        user_prompt = f"""
Сгенерируй один вопрос для группового чата Telegram.

Ограничения:
- не повторять эти вопросы или их смысл:
{used_block}
- желательно массово понятная тема
- уровень сложности: medium
- формат ответа — только JSON
""".strip()

        response = await self.client.chat.completions.create(
            model=self.model,
            temperature=0.8,
            messages=[
                {'role': 'system', 'content': SYSTEM_PROMPT},
                {'role': 'user', 'content': user_prompt},
            ],
        )

        content = response.choices[0].message.content or ''
        return self._parse_payload(content)

    def _parse_payload(self, content: str) -> QuestionPayload:
        raw = content.strip()

        if raw.startswith('```'):
            raw = raw.strip('`')
            raw = raw.replace('json', '', 1).strip()

        data: Any = json.loads(raw)
        return QuestionPayload.model_validate(data)

    def _pick_fallback_question(self, used_questions: Iterable[str]) -> dict[str, Any]:
        used_set = set(used_questions)
        candidates = [item for item in FALLBACK_QUESTIONS if item['question'] not in used_set]
        if not candidates:
            candidates = FALLBACK_QUESTIONS[:]
        return random.choice(candidates)
